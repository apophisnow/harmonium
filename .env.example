# ── Required for production (docker-compose.prod.yml) ──────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret
POSTGRES_PASSWORD=harmonium
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# ── Optional ───────────────────────────────────────────────────────────────────
# CLIENT_URL=http://localhost
# PORT=80
# MEDIASOUP_PREFER_TCP=true
# MAX_UPLOAD_SIZE=10485760
# DEFAULT_THEME=harmonium
# DEFAULT_MODE=dark

# SMTP (optional — if not set, verification URLs are logged to console)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@harmonium.app

# ── Local development (npm run dev) ───────────────────────────────────────────
DATABASE_URL=postgresql://harmonium:harmonium@localhost:5432/harmonium
REDIS_URL=redis://localhost:6379
UPLOAD_DIR=./uploads
